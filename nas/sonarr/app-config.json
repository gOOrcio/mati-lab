{
  "app_name": "sonarr",
  "custom_app": true,
  "values": {"ix_context": {}},
  "custom_compose_config": {
    "services": {
      "sonarr": {
        "image": "lscr.io/linuxserver/sonarr:latest",
        "restart": "unless-stopped",
        "environment": {
          "PUID": "568",
          "PGID": "568",
          "TZ": "Europe/Warsaw",
          "DOTNET_SYSTEM_NET_DISABLEIPV6": "true"
        },
        "volumes": [
          {"type": "bind", "source": "/mnt/fast/databases/sonarr/config", "target": "/config"},
          {"type": "bind", "source": "/mnt/bulk/data", "target": "/data"}
        ],
        "ports": [
          {"mode": "host", "protocol": "tcp", "published": 30026, "target": 8989}
        ],
        "labels": [
          "homepage.group=NAS",
          "homepage.name=Sonarr",
          "homepage.icon=sonarr.png",
          "homepage.href=https://sonarr.mati-lab.online",
          "homepage.description=TV series automation"
        ]
      }
    }
  }
}
