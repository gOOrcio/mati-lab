{
  "app_name": "bazarr",
  "custom_app": true,
  "values": {"ix_context": {}},
  "custom_compose_config": {
    "services": {
      "bazarr": {
        "image": "lscr.io/linuxserver/bazarr:latest",
        "restart": "unless-stopped",
        "environment": {
          "PUID": "568",
          "PGID": "568",
          "TZ": "Europe/Warsaw"
        },
        "volumes": [
          {"type": "bind", "source": "/mnt/fast/databases/bazarr/config", "target": "/config"},
          {"type": "bind", "source": "/mnt/bulk/data", "target": "/data"}
        ],
        "ports": [
          {"mode": "host", "protocol": "tcp", "published": 30028, "target": 6767}
        ]
      }
    }
  }
}
