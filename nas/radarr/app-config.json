{
  "app_name": "radarr",
  "custom_app": true,
  "values": {"ix_context": {}},
  "custom_compose_config": {
    "services": {
      "radarr": {
        "image": "lscr.io/linuxserver/radarr:latest",
        "restart": "unless-stopped",
        "environment": {
          "PUID": "568",
          "PGID": "568",
          "TZ": "Europe/Warsaw",
          "DOTNET_SYSTEM_NET_DISABLEIPV6": "true"
        },
        "volumes": [
          {"type": "bind", "source": "/mnt/fast/databases/radarr/config", "target": "/config"},
          {"type": "bind", "source": "/mnt/bulk/data", "target": "/data"}
        ],
        "ports": [
          {"mode": "host", "protocol": "tcp", "published": 30027, "target": 7878}
        ]
      }
    }
  }
}
