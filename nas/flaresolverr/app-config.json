{
  "app_name": "flaresolverr",
  "custom_app": true,
  "values": {"ix_context": {}},
  "custom_compose_config": {
    "services": {
      "flaresolverr": {
        "image": "ghcr.io/flaresolverr/flaresolverr:latest",
        "restart": "unless-stopped",
        "environment": {
          "TZ": "Europe/Warsaw",
          "LOG_LEVEL": "info",
          "LOG_HTML": "false",
          "CAPTCHA_SOLVER": "none"
        },
        "ports": [
          {"mode": "host", "protocol": "tcp", "published": 30030, "target": 8191}
        ]
      }
    }
  }
}
