{
  "app_name": "qbittorrent-mcp",
  "custom_app": true,
  "values": {"ix_context": {}},
  "custom_compose_config": {
    "services": {
      "qbittorrent-mcp": {
        "image": "gitea.mati-lab.online/gooral/qbittorrent-mcp:v1",
        "restart": "unless-stopped",
        "user": "568:568",
        "env_file": ["/mnt/fast/databases/qbittorrent-mcp/.env"],
        "environment": {
          "QBIT_BASE_URL": "http://192.168.1.65:30024",
