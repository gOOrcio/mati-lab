# ProtonVPN WireGuard credentials for Gluetun.
#
# Live file lives at /mnt/fast/databases/vpn-stack/.env on the NAS
# (root:root 0600, NOT in git). This file documents the expected shape.
#
# Generate the WireGuard config in ProtonVPN's web UI:
#   account.proton.me → VPN → WireGuard configuration → Create
#     Name:            vpn-stack-nas
#     Platform:        Linux
#     VPN Accelerator: ON
#     NAT-PMP (Port Forwarding): OFF (defer to followup 2.r.3)
#     Server:          Switzerland (or your preference; must be P2P-allowed)
#
# From the resulting `.conf` file, copy ONLY the `PrivateKey` line value.
# Save the full .conf to PM under `homelab/protonvpn/wireguard-config-vpn-stack-nas`
# and the private key alone under `homelab/protonvpn/wireguard-private-key`.

WIREGUARD_PRIVATE_KEY=<from PM homelab/protonvpn/wireguard-private-key>
