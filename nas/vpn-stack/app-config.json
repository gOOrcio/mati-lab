{
  "app_name": "vpn-stack",
  "custom_app": true,
  "values": {"ix_context": {}},
  "custom_compose_config": {
    "services": {
      "gluetun": {
        "image": "qmcgaw/gluetun:v3.41.1",
        "restart": "unless-stopped",
        "cap_add": ["NET_ADMIN"],
        "devices": ["/dev/net/tun:/dev/net/tun"],
        "env_file": ["/mnt/fast/databases/vpn-stack/.env"],
        "environment": {
          "VPN_SERVICE_PROVIDER": "protonvpn",
          "VPN_TYPE": "wireguard",
          "SERVER_COUNTRIES": "Switzerland",
          "FIREWALL_OUTBOUND_SUBNETS": "192.168.1.0/24,172.16.0.0/12",
          "TZ": "Europe/Warsaw",
          "DOT_PROVIDERS": "cloudflare",
          "BLOCK_MALICIOUS": "off",
          "HEALTH_VPN_DURATION_INITIAL": "30s",
          "VPN_PORT_FORWARDING": "on",
          "VPN_PORT_FORWARDING_PROVIDER": "protonvpn",
          "VPN_PORT_FORWARDING_UP_COMMAND": "/scripts/qbit-update-port.sh {{PORTS}}",
          "VPN_PORT_FORWARDING_STATUS_FILE": "/tmp/gluetun/forwarded_port",
          "HTTP_CONTROL_SERVER_AUTH_CONFIG_FILEPATH": "/gluetun-auth/auth.toml"
        },
        "ports": [
          {"mode": "host", "protocol": "tcp", "published": 30024, "target": 30024},
          {"mode": "host", "protocol": "tcp", "published": 30025, "target": 9696},
          {"mode": "host", "protocol": "tcp", "published": 30030, "target": 8191},
          {"mode": "host", "protocol": "tcp", "published": 8000, "target": 8000}
        ],
        "volumes": [
          {"type": "bind", "source": "/mnt/fast/databases/vpn-stack/scripts", "target": "/scripts", "read_only": true},
          {"type": "bind", "source": "/mnt/fast/databases/vpn-stack/gluetun-auth", "target": "/gluetun-auth", "read_only": true}
        ]
      },
      "qbittorrent": {
        "image": "ghcr.io/home-operations/qbittorrent:5.1.4",
        "restart": "unless-stopped",
        "network_mode": "service:gluetun",
        "depends_on": {"gluetun": {"condition": "service_healthy"}},
        "user": "568:568",
        "volumes": [
          {"type": "bind", "source": "/mnt/fast/databases/qbittorrent-config", "target": "/config"},
          {"type": "bind", "source": "/mnt/bulk/data/torrents", "target": "/downloads"}
        ]
      },
      "prowlarr": {
        "image": "lscr.io/linuxserver/prowlarr:latest",
        "restart": "unless-stopped",
        "network_mode": "service:gluetun",
        "depends_on": {"gluetun": {"condition": "service_healthy"}},
        "environment": {
          "PUID": "568",
          "PGID": "568",
          "TZ": "Europe/Warsaw",
          "DOTNET_SYSTEM_NET_DISABLEIPV6": "true"
        },
        "volumes": [
          {"type": "bind", "source": "/mnt/fast/databases/prowlarr/config", "target": "/config"}
        ]
      },
      "flaresolverr": {
        "image": "ghcr.io/flaresolverr/flaresolverr:latest",
        "restart": "unless-stopped",
        "network_mode": "service:gluetun",
        "depends_on": {"gluetun": {"condition": "service_healthy"}},
        "environment": {
          "TZ": "Europe/Warsaw",
          "LOG_LEVEL": "info",
          "LOG_HTML": "false",
          "CAPTCHA_SOLVER": "none"
        }
      }
    }
  }
}
