{
  "app_name": "hermes",
  "custom_app": true,
  "values": {"ix_context": {}},
  "custom_compose_config": {
    "services": {
      "hermes": {
        "image": "gitea.mati-lab.online/gooral/hermes-agent-investor:dev",
        "restart": "unless-stopped",
        "user": "0:0",
        "cap_add": ["CHOWN", "FOWNER", "SETUID", "SETGID", "DAC_OVERRIDE"],
        "shm_size": "1gb",
        "command": ["hermes", "gateway"],
        "environment": {
          "HERMES_UID": "568",
          "HERMES_GID": "568",
          "HERMES_HOME": "/opt/data",
          "HERMES_INVESTOR_DISCOVERY_UNIVERSE_PATH": "/opt/hermes-investor/data-template/discovery_universe.json",
          "HERMES_INVESTOR_DISCOVERY_SNAPSHOT_PATH": "/opt/data/hermes-investor/candidates.snapshot.json"
        },
        "env_file": ["/mnt/fast/databases/hermes/.env"],
        "volumes": [
          {"type": "bind", "source": "/mnt/.ix-apps/app_mounts/hermes/data", "target": "/opt/data"}
        ],
        "labels": [
          "homepage.group=NAS",
          "homepage.name=Hermes",
          "homepage.icon=mdi-robot",
          "homepage.href=https://hermes.mati-lab.online",
          "homepage.description=Investor agent gateway"
        ]
      },
      "hermes-dashboard": {
        "image": "gitea.mati-lab.online/gooral/hermes-agent-investor:dev",
        "restart": "unless-stopped",
        "user": "0:0",
        "cap_add": ["CHOWN", "FOWNER", "SETUID", "SETGID", "DAC_OVERRIDE"],
        "shm_size": "256m",
        "command": ["hermes", "dashboard", "--port", "9119", "--host", "0.0.0.0", "--no-open", "--insecure", "--tui"],
        "environment": {
          "HERMES_UID": "568",
          "HERMES_GID": "568",
          "HERMES_HOME": "/opt/data",
          "HERMES_INVESTOR_DISCOVERY_UNIVERSE_PATH": "/opt/hermes-investor/data-template/discovery_universe.json",
          "HERMES_INVESTOR_DISCOVERY_SNAPSHOT_PATH": "/opt/data/hermes-investor/candidates.snapshot.json",
          "TELEGRAM_BOT_TOKEN": ""
        },
        "env_file": ["/mnt/fast/databases/hermes/.env"],
        "volumes": [
          {"type": "bind", "source": "/mnt/.ix-apps/app_mounts/hermes/data", "target": "/opt/data"}
        ],
        "ports": [
          {"mode": "host", "protocol": "tcp", "published": 30262, "target": 9119}
        ],
        "depends_on": {"hermes": {"condition": "service_started"}}
      }
    }
  }
}
