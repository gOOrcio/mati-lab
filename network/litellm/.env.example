# LiteLLM gateway — required env. Real `.env` is gitignored.

# Master key for the LiteLLM admin API + any client that talks to the
# gateway (Hermes, OpenCode, etc.). Generate a fresh one per deployment:
#   python3 -c "import secrets;print('sk-' + secrets.token_urlsafe(32))"
LITELLM_MASTER_KEY=sk-change-me

# Provider API keys — create at:
#   https://platform.deepseek.com
#   https://platform.anthropic.com
DEEPSEEK_API_KEY=sk-change-me
ANTHROPIC_API_KEY=sk-ant-change-me
