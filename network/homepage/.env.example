# Pi-side env file for Homepage. Copy to .env on the Pi at
# /opt/mati-lab/network/homepage/.env (NOT in git).
#
# Each var is consumed by a Homepage widget defined in config/widgets.yaml.
# Empty / missing vars cause the relevant widget to render as "Missing"
# but do NOT break the rest of the dashboard.
#
# After editing this file: `make deploy-homepage BRANCH=main` from a dev
# PC, OR `cd /opt/mati-lab/network/homepage && docker compose up -d` on
# the Pi directly.

# --- Proxmox widget ---
# Mint a dedicated read-only token in PVE: Datacenter → Permissions →
# API Tokens → Add → user: homepage@pve, token id: dashboard,
# Privilege Separation: NO. Then add a permission row at path "/" with
# role PVEAuditor for user homepage@pve.
# The full token id is "<user>!<tokenid>" — i.e. "homepage@pve!dashboard".
PROXMOX_HOMEPAGE_TOKEN_ID=homepage@pve!dashboard
PROXMOX_HOMEPAGE_TOKEN_SECRET=<from password manager: homelab/proxmox/homepage-readonly>

# --- Homebridge widget ---
# Create a dedicated user in Homebridge Config-UI-X:
# Settings → Manage Users → Add Account → username: homepage, role:
# Read-only Access (or Admin if read-only is unavailable on your
# Homebridge version).
HOMEBRIDGE_USERNAME=homepage
HOMEBRIDGE_PASSWORD=<from password manager: homelab/homebridge/homepage>
