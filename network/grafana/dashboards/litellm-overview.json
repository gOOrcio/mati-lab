{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "uid": "litellm-overview",
  "title": "LiteLLM — Overview",
  "tags": ["litellm", "phase-7"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {"text": "Prometheus", "value": "Prometheus"},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total spend (USD, all-time)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "decimals": 2}
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {"expr": "sum(litellm_spend_metric_total)", "legendFormat": "spend", "refId": "A"}
      ]
    },
    {
      "id": 2,
      "title": "Requests / minute (5m avg)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "fieldConfig": {"defaults": {"unit": "rpm", "decimals": 1}},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {"expr": "sum(rate(litellm_proxy_total_requests_metric_total[5m])) * 60", "legendFormat": "rpm", "refId": "A"}
      ]
    },
    {
      "id": 3,
      "title": "Total tokens (in+out) / sec by alias",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {"expr": "sum by (requested_model) (rate(litellm_total_tokens_metric_total[5m]))", "legendFormat": "{{requested_model}}", "refId": "A"}
      ]
    },
    {
      "id": 4,
      "title": "Request rate by alias",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}},
      "targets": [
        {"expr": "sum by (requested_model) (rate(litellm_proxy_total_requests_metric_total{requested_model!=\"\"}[5m]))", "legendFormat": "{{requested_model}}", "refId": "A"}
      ]
    },
    {
      "id": 5,
      "title": "Request rate by status code",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}},
      "targets": [
        {"expr": "sum by (status_code) (rate(litellm_proxy_total_requests_metric_total[5m]))", "legendFormat": "{{status_code}}", "refId": "A"}
      ]
    },
    {
      "id": 6,
      "title": "P95 total latency by alias (s)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (requested_model, le) (rate(litellm_request_total_latency_metric_bucket[5m])))", "legendFormat": "{{requested_model}}", "refId": "A"}
      ]
    },
    {
      "id": 7,
      "title": "P95 LLM-API latency by model (s)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (model, le) (rate(litellm_llm_api_latency_metric_bucket[5m])))", "legendFormat": "{{model}}", "refId": "A"}
      ]
    },
    {
      "id": 8,
      "title": "Failed requests by exception class",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}},
      "targets": [
        {"expr": "sum by (exception_class, requested_model) (rate(litellm_proxy_failed_requests_metric_total[5m]))", "legendFormat": "{{requested_model}} / {{exception_class}}", "refId": "A"}
      ]
    },
    {
      "id": 9,
      "title": "Spend by model (cumulative)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["last"]}},
      "targets": [
        {"expr": "sum by (model) (litellm_spend_metric_total)", "legendFormat": "{{model}}", "refId": "A"}
      ]
    },
    {
      "id": 10,
      "title": "Per-key budget remaining (USD)",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 28},
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}},
      "options": {"showHeader": true},
      "targets": [
        {"expr": "litellm_remaining_api_key_budget_metric", "legendFormat": "{{api_key_alias}}", "refId": "A", "format": "table", "instant": true}
      ]
    }
  ]
}
