        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus-mati-lab" },
          "expr": "go_memstats_stack_inuse_bytes{job=\"restorate\"}",
          "legendFormat": "stack in-use"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineInterpolation": "smooth" } },
        "overrides": []
      },
      "options": {}
    },
