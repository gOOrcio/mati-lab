      "id": 24,
      "type": "timeseries",
      "title": "Goroutines",
      "gridPos": { "x": 12, "y": 69, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-mati-lab" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-mati-lab" },
          "expr": "go_goroutines{job=\"restorate\"}",
          "legendFormat": "goroutines"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineInterpolation": "smooth" } },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 25,
      "type": "timeseries",
