      "datasource": { "type": "prometheus", "uid": "prometheus-mati-lab" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-mati-lab" },
          "expr": "process_resident_memory_bytes{job=\"restorate\"}",
