    {
      "id": 28,
      "type": "row",
      "title": "Logs",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 85, "w": 24, "h": 1 }
    },
    {
      "id": 29,
      "type": "logs",
      "title": "Log Stream",
      "gridPos": { "x": 0, "y": 86, "w": 24, "h": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"restorate\"}"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "showLabels": false,
        "showTime": true,
        "wrapLogMessage": false,
        "sortOrder": "Descending"
      },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Error Log Count over Time",
      "gridPos": { "x": 0, "y": 98, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(rate({job=\"restorate\"} |= \"error\" [5m]))",
