### DIUN ###

# ntfy access token (required — ntfy uses deny-all default access)
# Generate a token in ntfy: ntfy token add --label=diun <username>
DIUN_NOTIF_NTFY_TOKEN=

# Gitea container registry PAT (read:package scope) — needed for Diun to
# query tags on gitea.mati-lab.online/gooral/* images.
# Generate at https://gitea.mati-lab.online/user/settings/applications
DIUN_GITEA_REGISTRY_PAT=
