*.mati-lab.online {
	tls {
		dns cloudflare {env.CF_API_TOKEN}
		resolvers 8.8.8.8 1.0.0.1
		propagation_delay 60s
		propagation_timeout -1
	}

	@pihole host pihole.mati-lab.online
	handle @pihole {
		@pihole_health path /api/info/version
		handle @pihole_health {
			reverse_proxy http://pihole:8080
		}

		handle {
			forward_auth http://authelia:9091 {
				uri /api/authz/forward-auth
				copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
			}
			@pihole_root path /
			redir @pihole_root /admin 301

			reverse_proxy http://pihole:8080 {
				header_up Host {host}
				header_up X-Forwarded-Proto https
				header_up X-Forwarded-Ssl on
			}
		}
	}

	@smart-resume host smart-resume.mati-lab.online
	handle @smart-resume {
		reverse_proxy 192.168.1.200:80
	}

	@restorate host restorate.mati-lab.online
	handle @restorate {
		reverse_proxy 192.168.1.203:80
	}

	@proxmox host proxmox.mati-lab.online
	handle @proxmox {
		@proxmox_health path /api2/json/version
		handle @proxmox_health {
			reverse_proxy 192.168.1.184:8006 {
				transport http {
					tls_insecure_skip_verify
				}
			}
		}

		handle {
			forward_auth http://authelia:9091 {
				uri /api/authz/forward-auth
				copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
			}
			reverse_proxy 192.168.1.184:8006 {
				transport http {
					tls_insecure_skip_verify
				}
			}
		}
	}

	@homebridge host homebridge.mati-lab.online
	handle @homebridge {
		@homebridge_health path /health
		handle @homebridge_health {
			reverse_proxy http://192.168.1.155:8581
		}

		handle {
			forward_auth http://authelia:9091 {
				uri /api/authz/forward-auth
				copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
			}
			reverse_proxy http://192.168.1.155:8581 {
				header_up Host {host}
				header_up X-Forwarded-Proto https
				header_up X-Forwarded-Ssl on
			}
		}
	}

	@nas host nas.mati-lab.online
	handle @nas {
		@nas_health path /health
		handle @nas_health {
			rewrite * /api/v2.0/system/ready
			reverse_proxy http://192.168.1.65
		}

		handle {
			forward_auth http://authelia:9091 {
				uri /api/authz/forward-auth
				copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
			}
			reverse_proxy http://192.168.1.65 {
				header_up Host {host}
				header_up X-Forwarded-Proto https
				header_up X-Forwarded-Ssl on
			}
		}
	}

	@uptime-kuma host uptime-kuma.mati-lab.online
	handle @uptime-kuma {
		forward_auth http://authelia:9091 {
			uri /api/authz/forward-auth
			copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
		}
		reverse_proxy http://uptime-kuma:3001 {
			header_up Host {host}
			header_up X-Forwarded-Proto https
			header_up X-Forwarded-Ssl on
			header_up Upgrade {>Upgrade}
			header_up Connection {>Connection}
		}
	}

