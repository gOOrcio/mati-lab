	@litellm host litellm.mati-lab.online
	handle @litellm {
		# LiteLLM runs on the NAS (TrueNAS Custom App), not on pihole-net.
		# Admin API / dashboard — Authelia 2FA required. Clients co-hosted
		# on the NAS (Hermes, future OpenCode) talk to LiteLLM directly
		# via http://localhost:4000 or the NAS docker bridge and don't
		# hit this vhost.
		forward_auth http://authelia:9091 {
			uri /api/authz/forward-auth
			copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
		}
		reverse_proxy http://192.168.1.65:4000 {
			header_up Host {host}
			header_up X-Forwarded-Proto https
			header_up X-Forwarded-Ssl on
		}
	}

	@openclaw host openclaw.mati-lab.online
	handle @openclaw {
		# OpenClaw dashboard (:30262) — NAS catalog app. Authelia 2FA
		# required for the web UI. Direct LAN access to 192.168.1.65:30262
		# bypasses Authelia; OpenClaw's own Gateway Token is the only
		# layer there.
		forward_auth http://authelia:9091 {
			uri /api/authz/forward-auth
			copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
		}
		reverse_proxy http://192.168.1.65:30262 {
			header_up Host {host}
			header_up X-Forwarded-Proto https
			header_up X-Forwarded-Ssl on
		}
	}

	@gitea host gitea.mati-lab.online
	handle @gitea {
		# NO forward_auth here. Authelia handles web SSO via Gitea's
		# OIDC client (Task 7), and git CLI uses PATs over HTTPS.
		# forward_auth would 302-redirect every `git push` to a 2FA
		# browser flow and break git completely. SSH (NAS:30009)
		# bypasses Caddy entirely (raw TCP).
		reverse_proxy http://192.168.1.65:30008 {
			header_up Host {host}
			header_up X-Forwarded-Proto https
			header_up X-Forwarded-Ssl on
		}
	}

	@obsidian host obsidian.mati-lab.online
	handle @obsidian {
		# NO forward_auth. obsidian-livesync plugin authenticates
		# directly against CouchDB with the `livesync` user; Authelia
		# in front would intercept the API auth flow (same trap as
		# Gitea). LAN/VPN-only — no Cloudflared route added.
		reverse_proxy http://192.168.1.65:30015 {
			header_up Host {host}
			header_up X-Forwarded-Proto https
			header_up X-Forwarded-Ssl on
		}
	}

	@syncthing host syncthing.mati-lab.online
	handle @syncthing {
		# Syncthing's HTTP GUI / REST API only — peer-to-peer sync
		# itself runs on port 22000 directly between Mac and NAS, not
		# through Caddy. forward_auth here is fine (no API client to
		# break, unlike gitea/obsidian). Syncthing's own GUI password
		# stays enabled as defense-in-depth for naked LAN access on
		# 192.168.1.65:30016. WebSocket headers for /rest/events.
		forward_auth http://authelia:9091 {
			uri /api/authz/forward-auth
			copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
		}
		reverse_proxy http://192.168.1.65:30016 {
			header_up Host {host}
			header_up X-Forwarded-Proto https
			header_up X-Forwarded-Ssl on
			header_up Upgrade {>Upgrade}
			header_up Connection {>Connection}
		}
	}

	@qdrant host qdrant.mati-lab.online
	handle @qdrant {
		# Qdrant dashboard + REST API behind Authelia 2FA. The watcher
		# service hits 192.168.1.65:30017 directly on the LAN — Caddy
		# is only here so we have a 2FA-gated UI for inspection.
		forward_auth http://authelia:9091 {
			uri /api/authz/forward-auth
			copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
		}
		reverse_proxy http://192.168.1.65:30017 {
