services:
  runner:
    image: gitea/runner:{{ gitea_runner_version }}-dind
    restart: unless-stopped
    privileged: true
    environment:
      GITEA_INSTANCE_URL: "{{ gitea_instance_url }}"
      GITEA_RUNNER_REGISTRATION_TOKEN_FILE: /secrets/runner-token
      CONFIG_FILE: /config/config.yaml
    volumes:
      - /var/lib/gitea-runner/data:/data
      - /var/lib/gitea-runner/config.yaml:/config/config.yaml:ro
      - /var/lib/gitea-runner/secrets/runner-token:/secrets/runner-token:ro
      # Wire the inner DinD to the Pi pull-through cache
      # (`network/registry-mirror/`). Without this, every build re-pulls the
      # 1.79GB Hermes base from Docker Hub over WAN.
      #
      # Rootful variant: the inner dockerd is the upstream dind one and reads
      # /etc/docker/daemon.json. Rootful is required here — rootless silently
      # disables cgroups inside a non-systemd container, which produced the
      # cleanup-race documented in KNOWN_FLAKE_act_runner_cleanup_race.md.
      - /var/lib/gitea-runner/daemon.json:/etc/docker/daemon.json:ro
    deploy:
      resources:
        limits:
          memory: 2560M
          cpus: '1.8'
