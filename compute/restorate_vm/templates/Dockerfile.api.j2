# syntax=docker/dockerfile:1

# ── Build stage ────────────────────────────────────────────────────────────────
FROM golang:1.25-alpine AS builder

RUN apk add --no-cache git curl

ARG BUF_VERSION=1.49.0
# Install buf CLI (pinned + checksum verified)
RUN curl -sSL "https://github.com/bufbuild/buf/releases/download/v${BUF_VERSION}/buf-Linux-x86_64" \
      -o /usr/local/bin/buf && \
    curl -sSL "https://github.com/bufbuild/buf/releases/download/v${BUF_VERSION}/buf-Linux-x86_64.sha256" \
      -o /tmp/buf.sha256 && \
    echo "$(cat /tmp/buf.sha256)  /usr/local/bin/buf" | sha256sum -c - && \
    chmod +x /usr/local/bin/buf && \
    rm /tmp/buf.sha256

# Install protoc plugins (pinned versions)
RUN go install google.golang.org/protobuf/cmd/protoc-gen-go@v1.36.5 && \
    go install connectrpc.com/connect/cmd/protoc-gen-connect-go@v1.17.0

WORKDIR /build

# Cache dependencies before copying source
COPY go.mod go.sum ./
RUN go mod download

# Copy source
COPY apps/api/ apps/api/
COPY packages/protos/ packages/protos/
COPY buf.yaml buf.gen.yaml ./

# Generate protobuf code
RUN buf generate

# Build binary — adjust the main package path if needed
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /api ./apps/api

# ── Runtime stage ──────────────────────────────────────────────────────────────
FROM alpine:3.21

RUN apk add --no-cache ca-certificates tzdata

WORKDIR /app
COPY --from=builder /api ./api

EXPOSE 3001
CMD ["./api"]
