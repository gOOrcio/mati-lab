# syntax=docker/dockerfile:1

# ── Build stage ────────────────────────────────────────────────────────────────
FROM golang:1.25-alpine AS builder

RUN apk add --no-cache git curl unzip

# Install buf CLI
RUN curl -sSL "https://github.com/bufbuild/buf/releases/latest/download/buf-Linux-x86_64" \
      -o /usr/local/bin/buf && chmod +x /usr/local/bin/buf

# Install protoc plugins
RUN go install google.golang.org/protobuf/cmd/protoc-gen-go@latest && \
    go install connectrpc.com/connect/cmd/protoc-gen-connect-go@latest

WORKDIR /build

# Cache dependencies before copying source
COPY go.mod go.sum ./
RUN go mod download

# Copy source
COPY apps/api/ apps/api/
COPY packages/protos/ packages/protos/
COPY buf.yaml buf.gen.yaml ./

# Generate protobuf code
RUN buf generate

# Build binary — adjust the main package path if needed
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /api ./apps/api/...

# ── Runtime stage ──────────────────────────────────────────────────────────────
FROM alpine:3.21

RUN apk add --no-cache ca-certificates tzdata

WORKDIR /app
COPY --from=builder /api ./api

EXPOSE 3001
CMD ["./api"]
