services:
  postgres:
    image: postgres:17-alpine
    container_name: restorate-db
    restart: unless-stopped
    env_file: postgres.env
    volumes:
      - pgdata:/var/lib/postgresql/data
    networks:
      - restorate-net
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ postgres_user }}"]
      interval: 10s
      timeout: 5s
      retries: 5

  valkey:
    image: valkey/valkey:8.0-alpine
    container_name: restorate-valkey
    restart: unless-stopped
    command: ["valkey-server", "/etc/valkey/valkey.conf"]
    environment:
      VALKEY_PASSWORD: "{{ valkey_password }}"
    volumes:
      - valkeydata:/data
      - ./valkey.conf:/etc/valkey/valkey.conf:ro
    networks:
      - restorate-net
    healthcheck:
      test: ["CMD-SHELL", "valkey-cli -a \"$$VALKEY_PASSWORD\" ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  api:
    image: "{{ registry_image_api }}"
    container_name: restorate-api
    restart: unless-stopped
    env_file: api.env
    depends_on:
      postgres:
        condition: service_healthy
      valkey:
        condition: service_healthy
    ports:
      - "3001:3001"  # Prometheus scrapes this directly; not routed through Caddy
    networks:
      - restorate-net

  web:
    image: "{{ registry_image_web }}"
    container_name: restorate-web
    restart: unless-stopped
    env_file: web.env
    depends_on:
      - api
    networks:
      - restorate-net

  caddy:
    image: caddy:2-alpine
    container_name: restorate-caddy
    restart: unless-stopped
    ports:
      - "80:80"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
    depends_on:
      - api
      - web
    networks:
      - restorate-net

volumes:
  pgdata:
  valkeydata:

networks:
  restorate-net:
    driver: bridge
