{
    # Structured JSON access log (written to stdout, picked up by Docker)
    log default {
        output stdout
        format json
        level INFO
    }
}

:80 {
    # Hide the server identity — infrastructure concern, not the app's job
    header -Server

    # Compress responses
    encode zstd gzip

    # Block Prometheus metrics from public access
    handle /metrics {
        respond 404
    }

    # Connect-RPC service routes — pattern: /<pkg>.<version>.<ServiceName>/
    # pkg names can contain underscores (e.g. google_maps)
    @connect_rpc path_regexp ^/[a-z][a-z0-9_]*\.[a-z][a-z0-9_]*\.[A-Z]
    handle @connect_rpc {
        reverse_proxy api:3001
    }

    # REST API routes
    handle /place-photo {
        reverse_proxy api:3001
    }
    handle /health {
        reverse_proxy api:3001
    }
    handle /export/reviews {
        reverse_proxy api:3001
    }
    handle /admin/invite-secret {
        reverse_proxy api:3001
    }

    # SvelteKit frontend
    handle {
        reverse_proxy web:3000
    }
}
